{
  "kind": "collectionType",
  "collectionName": "videos",
  "info": { "singularName": "video", "pluralName": "videos", "displayName": "Video" },
  "options": { "draftAndPublish": true },
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "title", "required": true },
    "canonicalPath": { "type": "string", "required": true },
    "youtubeUrl": { "type": "string", "required": true },
    "youtubeVideoId": { "type": "string" },
    "description": { "type": "text" },
    "videosPageAutoplay": { "type": "boolean", "default": false },
    "thumbnailOverride": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "seo": { "type": "component", "repeatable": false, "component": "shared.seo" },
    "legacyPaths": { "type": "component", "repeatable": true, "component": "shared.legacy-path" }
  }
}
